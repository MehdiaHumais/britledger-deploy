# ============================================================
# BritLedger AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --------------------------
# Application
# --------------------------
APP_NAME=BritLedger AI
APP_ENV=development
APP_DEBUG=True
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
FRONTEND_URL=https://ledger.britsyncai.com
ALLOWED_ORIGINS=https://ledger.britsyncai.com,capacitor://localhost,https://localhost,http://localhost,http://localhost:3000,http://127.0.0.1:3000

# --------------------------
# Security
# --------------------------
SECRET_KEY=your-super-secret-key-at-least-32-characters-long-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_RESET_TOKEN_EXPIRE_MINUTES=15

# --------------------------
# Database (PostgreSQL)
# --------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=britledger_db
POSTGRES_USER=britledger_user
POSTGRES_PASSWORD=your-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://britledger_user:your-strong-postgres-password@localhost:5432/britledger_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT=30

# --------------------------
# Redis
# --------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password
REDIS_DB=0
REDIS_URL=redis://:your-strong-redis-password@localhost:6379/0
CACHE_TTL_SECONDS=300

# --------------------------
# Celery
# --------------------------
CELERY_BROKER_URL=redis://:your-strong-redis-password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your-strong-redis-password@localhost:6379/2

# --------------------------
# Email (SMTP)
# --------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@britledger.ai
MAIL_FROM_NAME=BritLedger AI

# --------------------------
# AI Services
# --------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3

# --------------------------
# Payment Gateways (Stripe & PayPal)
# --------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CLIENT_ID=ca_your-stripe-connect-client-id
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_MODE=sandbox
RESEND_API_KEY=re_your-resend-key
ENCRYPTION_KEY=your-32-byte-base64-key

# --------------------------
# Rate Limiting
# --------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500
AUTH_RATE_LIMIT_PER_MINUTE=5

# --------------------------
# Sentry (Error Monitoring)
# --------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --------------------------
# File Storage
# --------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/uploads
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-2
AWS_S3_BUCKET=britledger-files

# --------------------------
# VAT / Company (UK)
# --------------------------
DEFAULT_VAT_RATE=20.0
VAT_REGISTRATION_NUMBER=GB000000000
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Your Company Address
COMPANY_CITY=London
COMPANY_POSTCODE=SW1A 1AA
COMPANY_COUNTRY=United Kingdom
COMPANY_PHONE=+44 20 0000 0000
COMPANY_EMAIL=info@yourcompany.com

# --------------------------
# Pagination
# --------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --------------------------
# Logging
# --------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/britledger.log
